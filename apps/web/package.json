{
  "name": "@openclaw-skill-center/web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json && node scripts/write-server-package.mjs && node scripts/rewrite-server-imports.mjs && node scripts/copy-server-runtime-deps.mjs",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "start": "node dist/server/server.js"
  },
  "dependencies": {
    "@openclaw-skill-center/core": "0.1.0",
    "@openclaw-skill-center/shared": "0.1.0",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "vite": "^7.1.7"
  }
}
